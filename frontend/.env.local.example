# ------------------------------------------------------------------
# The Inventory – Frontend Environment Variables
# ------------------------------------------------------------------
# Copy this file to .env.local and fill in the values for your setup.
#   cp .env.local.example .env.local
# ------------------------------------------------------------------

# Full URL for Django REST API calls from the browser.
# REQUIRED: Must include /api/v1 path.
# Development:  http://localhost:8000/api/v1
# Production:   https://api.example.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Application display name used in the UI metadata and page titles.
NEXT_PUBLIC_APP_NAME="The Inventory"
