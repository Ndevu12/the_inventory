# ------------------------------------------------------------------
# The Inventory – Frontend Environment Variables
# ------------------------------------------------------------------
# Copy this file to .env.local and fill in the values for your setup.
#   cp .env.local.example .env.local
# ------------------------------------------------------------------

# Base URL for the Django REST API (no trailing slash).
# In development this usually points at the local Django server.
# Falls back to "/api/v1" when unset (see src/lib/api-client.ts).
# Unset to use Next.js proxy (rewrites /api/* to Django at 8000).
# Set to hit Django directly (e.g. for CORS dev): http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=

# Application display name used in the UI metadata.
NEXT_PUBLIC_APP_NAME="The Inventory"
