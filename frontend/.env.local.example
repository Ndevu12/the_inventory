# ------------------------------------------------------------------
# The Inventory – Frontend Environment Variables
# ------------------------------------------------------------------
# Copy this file to .env.local and fill in the values for your setup.
#   cp .env.local.example .env.local
#
# IMPORTANT: Both API_SERVER_URL and NEXT_PUBLIC_API_URL should be configured together.
# ------------------------------------------------------------------

# [CLIENT-SIDE] Base URL for Django REST API calls from the browser.
# When set to a full URL (e.g. http://localhost:8000/api/v1), the frontend makes
# direct API calls to Django (useful for CORS debugging or separate API servers).
# When unset or set to /api/v1 (relative), requests use the Next.js proxy.
# Default: /api/v1 (uses Next.js rewrites, configured by API_SERVER_URL)
NEXT_PUBLIC_API_URL=

# [SERVER-SIDE] Base URL of the Django backend server (used by Next.js proxy rewrites).
# Next.js rewrites /api/:path* to {API_SERVER_URL}/api/:path*/
# This is configured in next.config.ts and is NOT exposed to the browser.
# Set this to match your Django server location:
#   Development:  http://localhost:8000
#   Production:   https://api.example.com (no trailing slash)
# Default: http://localhost:8000
API_SERVER_URL=http://localhost:8000

# Application display name used in the UI metadata and page titles.
NEXT_PUBLIC_APP_NAME="The Inventory"
