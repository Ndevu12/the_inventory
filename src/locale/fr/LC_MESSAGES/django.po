msgstr "Créer un utilisateur (définir le mot de passe)"

msgid "Create new user (send invitation)"
msgstr "Créer un utilisateur (envoyer une invitation)"

msgid "User"
msgstr "Utilisateur"

msgid "Select a user"
msgstr "Sélectionner un utilisateur"

msgid "Username"
msgstr "Nom d’utilisateur"

msgid "For new users only."
msgstr "Uniquement pour les nouveaux utilisateurs."

msgid "Email"
msgstr "E-mail"

msgid "Required when creating a new user."
msgstr "Obligatoire lors de la création d’un nouvel utilisateur."

