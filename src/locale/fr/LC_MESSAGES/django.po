#, python-format
msgid ""
"Are you sure you want to deactivate tenant \"%(name)s\"? Inactive tenants "
"cannot log in or access data."
msgstr ""
"Êtes-vous sûr de vouloir désactiver le locataire « %(name)s » ? Les "
"locataires inactifs ne peuvent pas se connecter ni accéder aux données."

msgid "Yes, deactivate"
msgstr "Oui, désactiver"

msgid "No, don't deactivate"
msgstr "Non, ne pas désactiver"

#, python-format
msgid "Are you sure you want to reactivate tenant \"%(name)s\"?"
msgstr "Voulez-vous vraiment réactiver le locataire « %(name)s » ?"

msgid "Yes, reactivate"
msgstr "Oui, réactiver"

msgid "No, cancel"
msgstr "Non, annuler"

msgid "No tenants created yet."
msgstr "Aucun locataire créé pour le moment."

