msgstr "Un locataire avec cet identifiant URL existe déjà."

msgid "Please select an existing user as owner."
msgstr "Veuillez sélectionner un utilisateur existant comme propriétaire."

msgid "Username is required for new users."
msgstr "Le nom d’utilisateur est obligatoire pour les nouveaux utilisateurs."

msgid "Email is required for new users."
msgstr "L’e-mail est obligatoire pour les nouveaux utilisateurs."

msgid "Password is required when creating a new user."
msgstr ""
"Le mot de passe est obligatoire lors de la création d’un nouvel utilisateur."

msgid "Email is required for invitation."
msgstr "L’e-mail est obligatoire pour l’invitation."

msgid "Deactivate tenant"
msgstr "Désactiver le locataire"

