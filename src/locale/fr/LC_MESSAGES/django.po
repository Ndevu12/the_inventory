msgid "Tenant '%(name)s' has been reactivated."
msgstr "Le locataire « %(name)s » a été réactivé."

msgid "You cannot impersonate yourself."
msgstr "Vous ne pouvez pas vous impersonner vous-même."

#, python-format
msgid "Now viewing as %(user)s."
msgstr "Vous consultez maintenant en tant que %(user)s."

msgid "Impersonation ended."
msgstr "Impersonation terminée."
