# =============================================================================
# The Inventory - Environment Configuration
# =============================================================================
#
# This file contains all environment variables used by The Inventory.
# Copy this to .env and update values for your environment.
#
# Required variables are marked with [REQUIRED].
# Optional variables have sensible defaults if not specified.
#
# =============================================================================
# CORE SETTINGS
# =============================================================================

# [REQUIRED] Django secret key for cryptographic signing
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# In development, the default insecure key is used if not specified
SECRET_KEY=

# Comma-separated list of allowed domain names for this Django site
# Required for production deployments
# Examples: example.com,api.example.com,www.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# [RECOMMENDED] PostgreSQL connection URL
# If not set, SQLite is used (suitable for development only)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Examples:
#   postgresql://postgres:password@localhost:5432/the_inventory
#   postgresql://user:pass@db.example.com:5432/inventory
DATABASE_URL=

# =============================================================================
# REDIS & CACHING
# =============================================================================

# Redis URL for caching and Celery message broker
# If not set, in-memory cache is used (development only)
# Format: redis://[host]:[port]/[db_number]
# Examples:
#   redis://localhost:6379/0
#   redis://redis-server:6379/1
#   redis://:password@redis.example.com:6379/0
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# CELERY TASK QUEUE
# =============================================================================

# Celery broker URL (where task messages are sent)
# Defaults to REDIS_URL if not specified
# Same format as REDIS_URL
CELERY_BROKER_URL=redis://localhost:6379/0

# Run Celery tasks synchronously in development/testing
# Set to true/1/yes to execute tasks immediately instead of async
# Useful for: development, testing, debugging
CELERY_TASK_ALWAYS_EAGER=false

# =============================================================================
# FRONTEND INTEGRATION
# =============================================================================

# Frontend application URL used in emails, auth redirects, and invitations
# Should match where your Next.js frontend is hosted
# Examples:
#   http://localhost:3000 (development)
#   https://app.example.com (production)
FRONTEND_URL=http://localhost:3000

# =============================================================================
# TENANT & REGISTRATION SETTINGS
# =============================================================================

# Enable public tenant registration via POST /auth/register/
# When true: anyone can create a new organization
# When false: only admins can create tenants
# Recommended: false for self-hosted, true for SaaS
ENABLE_PUBLIC_TENANT_REGISTRATION=false

# Enable audit logging for tenant access/switching
# Set to false in high-traffic systems to reduce overhead
AUDIT_TENANT_ACCESS=true

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# CORS_ALLOWED_ORIGINS is auto-configured to include:
#   - http://localhost:3000 (dev)
#   - http://localhost:5173 (dev)
#   - http://127.0.0.1:3000 (dev)
#   - http://127.0.0.1:5173 (dev)
# Additional origins can be added by modifying settings/production.py

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================

# Email backend for sending notifications and password resets
# In development, defaults to console output
# In production, configure for your email service:
#   smtp.gmail.com: EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#   SendGrid: EMAIL_BACKEND=sendgrid_backend.SendgridBackend
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-app-password

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
#
# DEVELOPMENT:
#   - PostgreSQL not required (SQLite used by default)
#   - Redis not required (in-memory cache used by default)
#   - Set CELERY_TASK_ALWAYS_EAGER=true for synchronous tasks
#   - Frontend must be running on http://localhost:3000
#
# PRODUCTION:
#   - [REQUIRED] Set SECRET_KEY to a secure random value
#   - [REQUIRED] Set DATABASE_URL to PostgreSQL instance
#   - [REQUIRED] Set ALLOWED_HOSTS to your domain name(s)
#   - [RECOMMENDED] Set up Redis for caching and Celery
#   - [RECOMMENDED] Configure EMAIL settings for notifications
#   - Set FRONTEND_URL to your production frontend domain
#   - Ensure DEBUG=False in production (configured in settings/production.py)
#   - Run: python manage.py migrate (after deploying)
#   - Run: python manage.py collectstatic (for static files)
#
# =============================================================================