# =============================================================================
# The Inventory - Environment Configuration
# =============================================================================
#
# This file contains all environment variables used by The Inventory.
# Copy this to .env and update values for your environment.
#
# Required variables are marked with [REQUIRED].
# Optional variables have sensible defaults if not specified.
#
# =============================================================================
# CORE SETTINGS
# =============================================================================

# [REQUIRED] Django secret key for cryptographic signing
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# In development, the default insecure key is used if not specified
SECRET_KEY=

# Comma-separated hostnames for Django ALLOWED_HOSTS only — no https://, no paths.
# Wrong: https://api.example.com/api   Right: api.example.com,.example.com
# Public deploy: set every hostname clients use (API gateway, ingress host, custom domain).
# Omitting the live host causes HTTP 400 (DisallowedHost).
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# i18n / paths (optional)
# -----------------------------------------------------------------------------
# LANGUAGE_CODE=en-us
# TIME_ZONE=UTC
# STATIC_URL=/static/
# MEDIA_URL=/media/

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# [RECOMMENDED] PostgreSQL connection URL
# If not set, SQLite is used (suitable for development only)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Examples:
#   postgresql://postgres:password@localhost:5432/the_inventory
#   postgresql://user:pass@db.example.com:5432/inventory
DATABASE_URL=

# =============================================================================
# AUTO-SEED — container startup only (NOT Django settings, NOT gunicorn flags)
# =============================================================================
#
# HOW THIS WORKS
#   • These are ordinary operating-system environment variables.
#   • They are read by scripts/entrypoint.sh when the container starts, after
#     `migrate` and before `gunicorn`. Nothing here is parsed from the gunicorn
#     command line or from Django’s settings modules.
#
# WHERE TO SET THEM
#   • Render: Dashboard → your Web Service → Environment → add key/value pairs.
#   • Docker CLI:  docker run -e AUTO_SEED_DATABASE=true … your-image
#   • Docker Compose:  services.web.environment  or  env_file: .env
#   • Kubernetes: Deployment spec env / ConfigMap / Secret.
#
# WHAT DOES *NOT* USE THESE
#   • Running `python manage.py runserver` or tests on your laptop — use
#     `python manage.py seed_database …` yourself; entrypoint.sh is not run.
#   • A bare `.env` file only affects processes that load it (e.g. Compose
#     env_file, or django-dotenv for manage.py). The Docker image entrypoint
#     does not source `.env` unless your orchestration injects those vars.
#
# TRUTHY VALUES (case-insensitive):  1, true, yes, on
#
# AUTO_SEED_DATABASE   — when truthy, run seed_database after migrations
# SEED_CLEAR             optional; truthy → pass --clear (destructive wipe of seeded tables)
# SEED_QUIET             optional; truthy → pass --quiet
# SEED_TENANT            optional; tenant slug → --tenant=… (omit to use --create-default / default tenant)
# SEED_MODELS            optional; e.g. categories,products → --models=… (see seed_database --help)
#
# Example (demo/staging only — creates default users/passwords from seeders):
#   AUTO_SEED_DATABASE=true
#

# =============================================================================
# REDIS & CACHING
# =============================================================================

# Redis URL for caching (production) and Celery broker (when workers are used).
# In production, if unset or empty, Django uses in-process LocMemCache so the app
# still runs without Redis (e.g. simple Render deploys). Set this when you add Redis.
# Format: redis://[host]:[port]/[db_number]
# Examples:
#   redis://localhost:6379/0
#   redis://redis-server:6379/1
#   redis://:password@redis.example.com:6379/0
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# CELERY TASK QUEUE
# =============================================================================

# Celery broker URL (where task messages are sent)
# Defaults to REDIS_URL if not specified
# Same format as REDIS_URL
CELERY_BROKER_URL=redis://localhost:6379/0

# Run Celery tasks synchronously in development/testing
# Set to true/1/yes to execute tasks immediately instead of async
# Useful for: development, testing, debugging
CELERY_TASK_ALWAYS_EAGER=false

# =============================================================================
# FRONTEND INTEGRATION
# =============================================================================

# Frontend application URL used in emails, auth redirects, and invitations
# Examples: http://localhost:3000  |  https://app.example.com
FRONTEND_URL=http://localhost:3000

# Public site URL (optional). Used as fallback for WAGTAILADMIN_BASE_URL when unset.
# Example: https://api.example.com  (your Django / Wagtail host, no trailing slash)
# PUBLIC_BASE_URL=

# Wagtail admin absolute URL base for emails (no /admin, no trailing slash).
# Defaults to PUBLIC_BASE_URL, then http://127.0.0.1:8000 for local dev.
# WAGTAILADMIN_BASE_URL=https://api.example.com

# Display name in Wagtail / templates (optional)
# WAGTAIL_SITE_NAME=the_inventory

# =============================================================================
# TENANT & REGISTRATION SETTINGS
# =============================================================================

# Enable public tenant registration via POST /auth/register/
# When true: anyone can create a new organization
# When false: only admins can create tenants
# Recommended: false for self-hosted, true for SaaS
ENABLE_PUBLIC_TENANT_REGISTRATION=false

# Enable audit logging for tenant access/switching
# Set to false in high-traffic systems to reduce overhead
AUDIT_TENANT_ACCESS=true

# =============================================================================
# CORS & CSRF (separate frontend / API — set in production)
# =============================================================================
#
# Comma-separated origins: scheme + host + port, no path.
# If CORS_ALLOWED_ORIGINS is unset, defaults include localhost:3000 and :5173 (Vite).
#
# Production example (Render API + Vercel app):
#   CORS_ALLOWED_ORIGINS=https://my-app.vercel.app
#   CSRF_TRUSTED_ORIGINS=https://my-app.vercel.app
#
# CSRF_TRUSTED_ORIGINS — browsers sending cookies / session auth to the API must list
# the frontend origin here. If unset, it defaults to the same list as CORS_ALLOWED_ORIGINS.
# If CORS_ALLOW_ALL_ORIGINS=true, you MUST set CSRF_TRUSTED_ORIGINS explicitly.
#
# CORS_ALLOW_ALL_ORIGINS=true   # dev only; cannot use with credentialed browser auth
# CORS_ALLOW_CREDENTIALS=true   # default true (JWT in header / cookies)
# CORS_EXTRA_HEADERS=           # optional comma-separated extra allowed request headers
#
# Cross-site cookies (HTTPS SPA on another domain — often needs):
#   SESSION_COOKIE_SAMESITE=None
#   SESSION_COOKIE_SECURE=true
#   CSRF_COOKIE_SAMESITE=None
#   CSRF_COOKIE_SECURE=true
# (Production settings default SESSION_COOKIE_SECURE / CSRF_COOKIE_SECURE to true unless overridden.)
#
# Trust X-Forwarded-Proto from your edge (load balancer, ingress, PaaS). Default in production is on;
# set false only if TLS terminates on the app and no proxy sends this header.
# USE_X_FORWARDED_PROTO=false

# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# CSRF_TRUSTED_ORIGINS=http://localhost:3000

# =============================================================================
# REST API & JWT (optional)
# =============================================================================
# API_PAGE_SIZE=25
# JWT_ACCESS_TOKEN_MINUTES=30
# JWT_REFRESH_TOKEN_DAYS=7

# =============================================================================
# CACHE TTLs (seconds, optional)
# =============================================================================
# STOCK_CACHE_TTL_SECONDS=600
# DASHBOARD_CACHE_TTL_SECONDS=300

# =============================================================================
# OPENAPI / SPECTACULAR (optional)
# =============================================================================
# API_DOC_TITLE=The Inventory API
# API_DOC_DESCRIPTION=RESTful API for The Inventory
# API_DOC_VERSION=1.0.0

# =============================================================================
# FORMS / UPLOADS (optional)
# =============================================================================
# DATA_UPLOAD_MAX_NUMBER_FIELDS=10000

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================

# Set EMAIL_BACKEND to override (dev.py may still force console in local dev).
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_USE_SSL=false
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@example.com

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
#
# DEVELOPMENT:
#   - PostgreSQL not required (SQLite used by default)
#   - Redis not required (in-memory cache used by default)
#   - Set CELERY_TASK_ALWAYS_EAGER=true for synchronous tasks
#   - Frontend must be running on http://localhost:3000
#
# PRODUCTION:
#   - [REQUIRED] Set SECRET_KEY to a secure random value
#   - [REQUIRED] Set DATABASE_URL to PostgreSQL instance
#   - [REQUIRED] Set ALLOWED_HOSTS to your domain name(s)
#   - [RECOMMENDED] Set up Redis for caching and Celery
#   - [RECOMMENDED] Configure EMAIL settings for notifications
#   - Set FRONTEND_URL to your production frontend domain
#   - Ensure DEBUG=False in production (configured in settings/production.py)
#   - Run: python manage.py migrate (after deploying)
#   - Run: python manage.py collectstatic (for static files)
#
# =============================================================================